# === Robot AI Server - Soren Configuration ===
# Скопируй в .env и настрой под себя

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# --- WiFi (ESP32 подключается к этой сети) ---
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# --- Paths ---
MODELS_DIR=./models
AUDIO_CACHE_DIR=./audio_cache

# --- STT (faster-whisper) — только локальный ---
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- TTS (Silero) ---
SILERO_SPEAKER=xenia

# --- LLM (llama.cpp) ---
LLM_MODEL_PATH=./models/Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLM_N_CTX=4096
LLM_N_THREADS=4
LLM_TEMPERATURE=0.7

# --- GitHub Models API (бесплатный LLM, без VPN) ---
# Получи токен: https://github.com/settings/tokens
# Нужны права: read:packages, models:read
# Или через GitHub Models: https://github.com/marketplace/models
GITHUB_MODELS_KEY=ghp_your_github_token_here
GITHUB_MODELS_NAME=gpt-4o-mini
# Другие модели: gpt-4o, meta-llama-3.1-70b-instruct, mistral-large

# --- FreeTTS (edge-tts) — бесплатный облачный TTS ---
# Голоса: ru-RU-SvetlanaNeural, ru-RU-DmitryNeural, ru-RU-EkaterinaNeural
FREETTS_VOICE=ru-RU-SvetlanaNeural
FREETTS_SPEED=1.0

# --- Vision ---
YOLO_MODEL=./models/yolov8n.pt
ENABLE_POSE_TRACKING=true

# --- Audio ---
SAMPLE_RATE=16000
CHUNK_DURATION_MS=30
VAD_AGGRESSIVENESS=2
SILENCE_TIMEOUT_MS=1500

# --- OpenMP fix ---
KMP_DUPLICATE_LIB_OK=TRUE

CHARACTER=./character/Soren.txt